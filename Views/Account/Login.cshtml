@model PerfumeStore.Models.User

@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center">
    <div class="col-md-5 mt-5">
        <div class="card glass-card border-0 p-4">
            <div class="text-center mb-4">
                <i class="bi bi-person-circle display-4 text-warning mb-3"></i>
                <h3 class="fw-bold text-light">Welcome Back</h3>
                <p class="text-muted small">Sign in to your Royal Scent account</p>
            </div>
            
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger text-center rounded-3">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label text-light-emphasis small fw-bold">Email Address</label>
                    <input type="email" name="email" class="form-control bg-dark text-light border-secondary" required />
                </div>
                
                <div class="mb-4">
                    <label class="form-label text-light-emphasis small fw-bold">Password</label>
                    <input type="password" name="password" class="form-control bg-dark text-light border-secondary" required />
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold rounded-pill mb-3">Sign In</button>
                
                <div class="text-center mt-3">
                    <span class="text-muted small">Don't have an account? </span>
                    <a asp-action="Register" class="text-warning text-decoration-none small fw-bold">Create Account</a>
                </div>
            </form>
        </div>
    </div>
</div>
