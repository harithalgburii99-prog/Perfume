@model PerfumeStore.Models.User

@{
    ViewBag.Title = "تسجيل حساب جديد";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <i class="fas fa-user-plus auth-icon"></i>
            <h2>إنشاء حساب جديد</h2>
            <p class="auth-subtitle">انضم إلى متجر العطور الملكي</p>
        </div>

        @* BUG FIX #13: Missing AntiForgeryToken on Register form too *@
        @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "auth-form" }))
        {
            @Html.AntiForgeryToken()

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger text-center">
                    <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.Error
                </div>
            }

            <div class="form-group mb-4">
                <label class="form-label">اسم المستخدم</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "اسمك هنا", required = "required" })
                </div>
                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small" })
            </div>

            <div class="form-group mb-4">
                <label class="form-label">البريد الإلكتروني</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    @* BUG FIX #14: TextBoxFor on email doesn't set type="email".
                       Use explicit htmlAttributes to enforce correct input type. *@
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "example@mail.com", type = "email", required = "required" })
                </div>
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
            </div>

            <div class="form-group mb-4">
                <label class="form-label">كلمة المرور</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "••••••••", required = "required" })
                </div>
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
            </div>

            <button type="submit" class="btn-auth w-100">
                <i class="fas fa-user-plus me-2"></i> إنشاء الحساب
            </button>

            <p class="text-center mt-4 text-muted small">
                لديك حساب بالفعل؟ <a href="/Account/Login" class="link-gold">سجّل دخولك</a>
            </p>
        }
    </div>
</div>

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 20px;
    }

    .auth-card {
        background: #fff;
        border-top: 4px solid #b8860b;
        padding: 50px 40px;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    }

    .auth-header { text-align: center; margin-bottom: 35px; }
    .auth-icon { font-size: 2.5rem; color: #b8860b; margin-bottom: 15px; display: block; }
    .auth-header h2 { font-weight: 800; color: #1a1a1a; margin-bottom: 5px; }
    .auth-subtitle { color: #999; font-size: 0.9rem; }

    .form-label { font-weight: 600; color: #444; font-size: 0.9rem; margin-bottom: 8px; }

    .input-group-text { background: #f9f9f9; border-color: #eee; color: #b8860b; }

    .form-control { border-color: #eee; padding: 10px 15px; font-size: 0.95rem; }
    .form-control:focus { border-color: #b8860b; box-shadow: 0 0 0 3px rgba(184,134,11,0.1); }

    .btn-auth {
        background: #1a1a1a;
        color: white;
        border: none;
        padding: 14px;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-auth:hover { background: #b8860b; }
    .link-gold { color: #b8860b; text-decoration: none; font-weight: 600; }
    .link-gold:hover { text-decoration: underline; }
</style>

