@model PerfumeStore.Models.User

@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center">
    <div class="col-md-5 mt-5">
        <div class="card glass-card border-0 p-4">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus display-4 text-warning mb-3"></i>
                <h3 class="fw-bold text-light">Create Account</h3>
                <p class="text-muted small">Join the Royal Scent family</p>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label text-light-emphasis small fw-bold">Username</label>
                    <input asp-for="Username" class="form-control bg-dark text-light border-secondary" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-light-emphasis small fw-bold">Email Address</label>
                    <input asp-for="Email" class="form-control bg-dark text-light border-secondary" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label text-light-emphasis small fw-bold">Password</label>
                    <input asp-for="Password" class="form-control bg-dark text-light border-secondary" type="password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold rounded-pill mb-3">Create Account</button>

                <div class="text-center mt-3">
                    <span class="text-muted small">Already have an account? </span>
                    <a asp-action="Login" class="text-warning text-decoration-none small fw-bold">Sign In</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
