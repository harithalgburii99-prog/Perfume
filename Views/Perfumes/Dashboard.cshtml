@model IEnumerable<PerfumeStore.Models.Perfume>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-light fw-bold"><i class="bi bi-speedometer2 text-warning me-2"></i>Dashboard</h2>
    <a asp-action="Create" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm"><i class="bi bi-plus-lg me-1"></i>Add Perfume</a>
</div>

<div class="card glass-card border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 bg-transparent">
                <thead class="text-warning border-bottom border-secondary">
                    <tr>
                        <th class="ps-4">Image</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th class="pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="align-middle border-bottom border-secondary border-opacity-25">
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="@item.ImagePath" class="rounded object-fit-cover shadow-sm" width="60" height="60" alt="@item.Name" />
                                }
                                else
                                {
                                    <div class="bg-secondary bg-opacity-25 rounded d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-semibold text-light">@item.Name</td>
                            <td class="text-light-emphasis small text-truncate" style="max-width: 250px;">@item.Description</td>
                            <td class="text-light">$@item.Price?.ToString("0.00")</td>
                            <td class="pe-4 text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-2">Edit</a>
                                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this perfume?');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">No perfumes found in the database.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
