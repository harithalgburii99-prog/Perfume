@model PerfumeStore.Models.Perfume

@{
    ViewData["Title"] = "Add Perfume";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-light fw-bold"><i class="bi bi-plus-circle text-warning me-2"></i>Add New Perfume</h2>
            <a asp-action="Dashboard" class="btn btn-outline-light rounded-pill px-4">Back to Dashboard</a>
        </div>

        <div class="card glass-card border-0 p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-4">
                    <label asp-for="Name" class="form-label text-light-emphasis small fw-bold">Perfume Name</label>
                    <input asp-for="Name" class="form-control bg-dark text-light border-secondary" placeholder="e.g. Amber Wood" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label text-light-emphasis small fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control bg-dark text-light border-secondary" rows="3" placeholder="Describe the fragrance notes..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label text-light-emphasis small fw-bold">Price ($)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control bg-dark text-light border-secondary" placeholder="0.00" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ImagePath" class="form-label text-light-emphasis small fw-bold">Image URL</label>
                        <input asp-for="ImagePath" class="form-control bg-dark text-light border-secondary" placeholder="https://..." />
                        <span asp-validation-for="ImagePath" class="text-danger small"></span>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-warning rounded-pill px-5 fw-bold shadow-sm">Save Perfume</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
