@model IEnumerable<PerfumeStore.Models.CartViewModel>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h2 class="text-light fw-bold"><i class="bi bi-cart3 me-2 text-warning"></i>Your Cart</h2>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success bg-success bg-opacity-10 border-success text-success rounded-3 mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Message"]
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card glass-card border-0 mb-4">
            <div class="card-body p-0">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0 bg-transparent">
                            <thead class="text-warning">
                                <tr>
                                    <th class="ps-4">Product</th>
                                    <th>Price</th>
                                    <th class="pe-4 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="align-middle">
                                        <td class="ps-4 text-light fw-semibold">@item.PerfumeName</td>
                                        <td class="text-light-emphasis">$@item.Price.ToString("0.00")</td>
                                        <td class="pe-4 text-end">
                                            <form asp-action="Remove" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.CartId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-cart-x display-1 text-muted mb-3 opacity-25"></i>
                        <h4 class="text-light-emphasis">Your cart is empty.</h4>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-warning rounded-pill mt-3 px-4">Continue Shopping</a>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="col-lg-4">
            <div class="card glass-card border-0 sticky-top" style="top: 2rem;">
                <div class="card-body p-4">
                    <h5 class="card-title text-light fw-bold mb-4">Order Summary</h5>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-light-emphasis">Subtotal</span>
                        <span class="text-light fw-semibold">$@Model.Sum(x => x.Price).ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-light-emphasis">Shipping</span>
                        <span class="text-success fw-semibold">Free</span>
                    </div>
                    
                    <hr class="border-secondary my-4">
                    
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-light fw-bold fs-5">Total</span>
                        <span class="text-warning fw-bold fs-5">$@Model.Sum(x => x.Price).ToString("0.00")</span>
                    </div>

                    <form asp-action="Checkout" method="post">
                        <button type="submit" class="btn btn-warning w-100 py-3 rounded-pill fw-bold text-dark shadow-sm">
                            Proceed to Checkout <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
