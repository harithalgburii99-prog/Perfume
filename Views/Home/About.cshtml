@{
    ViewData["Title"] = "About Us";
}

<div class="row align-items-center mb-5">
    <div class="col-lg-6 mb-4 mb-lg-0">
        <h1 class="display-4 fw-bold text-gradient mb-4">The Essence of Luxury</h1>
        <p class="lead text-light">At Royal Scent, we believe that a fragrance is more than just a scent—it's an invisible signature, a memory waiting to be made, and the ultimate expression of personal style.</p>
        <p class="text-light-emphasis">Founded with a passion for exceptional olfactory experiences, our curated collection features only the finest, most exclusive perfumes from master perfumers around the globe. Every bottle we offer represents the pinnacle of craftsmanship and artistry.</p>
        <p class="text-light-emphasis">We are dedicated to helping you discover the perfect fragrance that resonates with your unique personality and elevates your everyday moments into extraordinary memories.</p>
    </div>
    <div class="col-lg-6">
        <div class="glass-card p-2 text-center position-relative overflow-hidden" style="min-height: 400px; border-radius: 2rem;">
            <div class="position-absolute w-100 h-100" style="background: radial-gradient(circle at center, rgba(157, 78, 221, 0.2) 0%, transparent 70%); top: 0; left: 0;"></div>
            <div class="d-flex h-100 align-items-center justify-content-center">
                <i class="bi bi-droplet-half text-warning opacity-75" style="font-size: 15rem;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row text-center mt-5">
    <div class="col-md-4 mb-4">
        <div class="glass-card p-4 h-100 hover-lift">
            <i class="bi bi-gem text-warning fs-1 mb-3"></i>
            <h3 class="text-light">Exquisite Quality</h3>
            <p class="text-light-emphasis small">Sourced from the world's finest ingredients.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="glass-card p-4 h-100 hover-lift">
            <i class="bi bi-shield-check text-warning fs-1 mb-3"></i>
            <h3 class="text-light">100% Authentic</h3>
            <p class="text-light-emphasis small">Guaranteed genuine products direct from the brands.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="glass-card p-4 h-100 hover-lift">
            <i class="bi bi-box-seam text-warning fs-1 mb-3"></i>
            <h3 class="text-light">Premium Packaging</h3>
            <p class="text-light-emphasis small">Every order is hand-packed with the utmost care.</p>
        </div>
    </div>
</div>
