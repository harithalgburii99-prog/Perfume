@{
    ViewData["Title"] = "Contact Us";
}

<div class="row justify-content-center mb-5">
    <div class="col-md-8 text-center">
        <h1 class="display-4 fw-bold text-gradient mb-3">Get in Touch</h1>
        <p class="lead text-light">Have a question about our fragrances or need assistance with your order? Our concierge team is here to help.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-5 mb-4 mb-md-0">
        <div class="glass-card p-4 h-100">
            <h3 class="text-light mb-4">Contact Information</h3>
            
            <div class="d-flex align-items-center mb-4">
                <div class="bg-dark bg-opacity-50 p-3 rounded-circle me-3 border border-secondary border-opacity-25">
                    <i class="bi bi-geo-alt text-warning fs-4"></i>
                </div>
                <div>
                    <h5 class="text-light mb-1">Our Boutique</h5>
                    <p class="text-light-emphasis small mb-0">123 Luxury Avenue<br>New York, NY 10001</p>
                </div>
            </div>

            <div class="d-flex align-items-center mb-4">
                <div class="bg-dark bg-opacity-50 p-3 rounded-circle me-3 border border-secondary border-opacity-25">
                    <i class="bi bi-envelope text-warning fs-4"></i>
                </div>
                <div>
                    <h5 class="text-light mb-1">Email Us</h5>
                    <p class="text-light-emphasis small mb-0">concierge@royalscent.com</p>
                </div>
            </div>

            <div class="d-flex align-items-center">
                <div class="bg-dark bg-opacity-50 p-3 rounded-circle me-3 border border-secondary border-opacity-25">
                    <i class="bi bi-telephone text-warning fs-4"></i>
                </div>
                <div>
                    <h5 class="text-light mb-1">Call Us</h5>
                    <p class="text-light-emphasis small mb-0">+1 (555) 123-4567<br><span class="text-muted">Mon-Fri, 9am-6pm EST</span></p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-7">
        <div class="glass-card p-4">
            <h3 class="text-light mb-4">Send a Message</h3>
            <form>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-light-emphasis small fw-bold">First Name</label>
                        <input type="text" class="form-control bg-dark text-light border-secondary hover-border" placeholder="John">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-light-emphasis small fw-bold">Last Name</label>
                        <input type="text" class="form-control bg-dark text-light border-secondary hover-border" placeholder="Doe">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-light-emphasis small fw-bold">Email Address</label>
                    <input type="email" class="form-control bg-dark text-light border-secondary hover-border" placeholder="john@example.com">
                </div>
                <div class="mb-4">
                    <label class="form-label text-light-emphasis small fw-bold">Message</label>
                    <textarea class="form-control bg-dark text-light border-secondary hover-border" rows="5" placeholder="How can we help you today?"></textarea>
                </div>
                <button type="submit" class="btn btn-warning rounded-pill px-5 fw-bold shadow-sm w-100 w-md-auto glow-on-hover">Send Message</button>
            </form>
        </div>
    </div>
</div>
