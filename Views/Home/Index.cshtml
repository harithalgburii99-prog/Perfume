@model IEnumerable<PerfumeStore.Models.Perfume>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center hero-section py-5 mb-5 rounded-4 glass-panel">
    <h1 class="display-3 fw-bold text-gradient mb-3">Royal Scent</h1>
    <p class="lead text-light-emphasis">Discover the essence of luxury and elegance.</p>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 perfume-card glass-card border-0">
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" class="card-img-top perfume-img" alt="@item.Name">
                    }
                    else
                    {
                        <div class="card-img-top perfume-img bg-dark d-flex align-items-center justify-content-center">
                            <i class="bi bi-image text-muted fs-1"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-light">@item.Name</h5>
                        <p class="card-text text-muted small">@item.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fs-5 fw-semibold text-warning">$@(item.Price.HasValue ? item.Price.Value.ToString("0.00") : "0.00")</span>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    <input type="hidden" name="perfumeId" value="@item.Id" />
                                    <button type="submit" class="btn btn-warning btn-sm rounded-pill px-3 fw-bold">Add to Cart</button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-warning btn-sm rounded-pill px-3">Sign in to buy</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <h4 class="text-muted">No perfumes available at the moment.</h4>
        </div>
    }
</div>
