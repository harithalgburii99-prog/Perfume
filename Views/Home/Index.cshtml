@model IEnumerable<PerfumeStore.Models.Perfume>

@{
    ViewBag.Title = "الرئيسية";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero {
        background: #1a1a1a;
        color: white;
        padding: 80px 20px;
        border-radius: 4px;
        text-align: center;
        margin-bottom: 40px;
        border-left: 5px solid #b8860b;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .hero h1 { font-family: 'Playfair Display', serif; color: #b8860b; font-weight: bold; }

    .btn-custom {
        background-color: #b8860b;
        color: white;
        padding: 12px 40px;
        border-radius: 0;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
        display: inline-block;
        text-transform: uppercase;
        border: none;
    }

    .btn-custom:hover { background-color: #966d08; color: white; transform: translateY(-3px); box-shadow: 0 5px 15px rgba(184,134,11,0.3); }

    .features-box { display: flex; justify-content: center; gap: 20px; margin-bottom: 50px; flex-wrap: wrap; }

    .feature-card {
        width: 300px; padding: 30px; background: #fff; border: none;
        border-radius: 0; text-align: center; box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        border-top: 3px solid transparent; transition: 0.3s;
    }

    .feature-card:hover { border-top: 3px solid #b8860b; transform: translateY(-5px); }
    .feature-card h3 { color: #b8860b; font-size: 1.3rem; margin-bottom: 15px; }

    .perfume-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px; padding: 20px 0; }

    .perfume-card {
        background: white; border-radius: 0; border: 1px solid #eee;
        padding: 30px; text-align: center; transition: 0.4s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        display: flex; flex-direction: column; justify-content: space-between; min-height: 250px;
    }

    .perfume-card:hover { box-shadow: 0 15px 35px rgba(0,0,0,0.1); transform: translateY(-10px); border-color: #b8860b; }
    .perfume-card h3 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.4rem; color: #1a1a1a; margin-bottom: 10px; }

    .perfume-description { color: #666; font-size: 0.95rem; margin-bottom: 20px; line-height: 1.6; }
    .price-tag { color: #b8860b; font-size: 1.6rem; font-weight: bold; margin: 15px 0; }

    .btn-buy-now {
        background-color: #1a1a1a; color: white; border-radius: 0;
        padding: 12px; transition: 0.3s; border: none;
        text-transform: uppercase; letter-spacing: 1px;
        display: block; text-align: center; text-decoration: none; width: 100%;
    }

    .btn-buy-now:hover { background-color: #b8860b; color: white; }

    h2.section-title {
        text-align: center; margin: 60px 0 40px; font-weight: 800;
        color: #1a1a1a; text-transform: uppercase; letter-spacing: 2px; position: relative;
    }

    h2.section-title::after { content: ''; display: block; width: 60px; height: 3px; background: #b8860b; margin: 10px auto; }
</style>

<div class="hero shadow">
    <h1><i class="fas fa-crown"></i> Royal Perfume Store</h1>
    <p>Discover luxury perfumes with the best prices and exceptional quality</p>
    <a href="#our-perfumes" class="btn-custom">Shop Collection</a>
</div>

<div class="features-box">
    <div class="feature-card">
        <h3><i class="fas fa-gem"></i> Luxury Perfumes</h3>
        <p class="text-muted small">High quality branded perfumes from world-class makers.</p>
    </div>
    <div class="feature-card">
        <h3><i class="fas fa-shipping-fast"></i> Fast Delivery</h3>
        <p class="text-muted small">Quick and safe delivery right to your doorstep.</p>
    </div>
    <div class="feature-card">
        <h3><i class="fas fa-tags"></i> Best Prices</h3>
        <p class="text-muted small">Affordable luxury for everyone with daily offers.</p>
    </div>
</div>

<hr style="opacity:0.1;" />

<div id="our-perfumes">
    <h2 class="section-title">Our Collection</h2>

    @* BUG FIX #31: No null check — if DB is empty or fails, Model is null → crash *@
    @if (Model != null && Model.Any())
    {
        <div class="perfume-grid">
            @foreach (var item in Model)
            {
                <div class="perfume-card">
                    <div>
                        <h3>@item.Name</h3>
                        <p class="perfume-description">@item.Description</p>
                    </div>
                    <div>
                        @* BUG FIX #32: item.Price is nullable decimal — direct @item.Price $
                           would render "$ " (blank) if null. Guard it. *@
                        <p class="price-tag">
                            @(item.Price.HasValue ? item.Price.Value.ToString("0.00") + " $" : "—")
                        </p>
                        <a href="@Url.Action("Buy", "Perfumes", new { id = item.Id })" class="btn-buy-now fw-bold">
                            شراء الآن
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-center text-muted py-5">لا توجد عطور متاحة حالياً. تابعنا قريباً!</p>
    }
</div>

@if (User.IsInRole("Admin"))
{
    <div class="text-center" style="margin:40px">
        <a href="@Url.Action("Create", "Perfumes")" class="btn btn-outline-dark px-5 py-2" style="border-radius:0">
            <i class="fas fa-plus-circle me-2"></i> إضافة عطر جديد للمتجر
        </a>
    </div>
}

